# Lokal ishga tushirish (npm run dev) — default /api/v1 ishlatiladi, sozlash shart emas
# VITE_API_BASE_URL=/api/v1

# Production API (build/deploy uchun)
# VITE_API_BASE_URL=https://api.arxivfjsti.uz/api/v1

# Speech token — productionda frontend server (/api/v1/speech/token), default: /api/v1
# VITE_SPEECH_API_BASE_URL=/api/v1

# Azure Speech — Ziyrak ovozli yordamchi (npm run dev va production server)
# AZURE_SPEECH_KEY=your-azure-speech-key
# AZURE_SPEECH_REGION=eastus
# AZURE_SPEECH_LANGUAGE=uz-UZ
